{
  "baseUrl": "http://localhost:3019/api",
  "auth": {
    "header": "Authorization: <TOKEN>",
    "tokenSource": "POST /login (mavjud SAP login)",
    "adminRoles": ["CEO", "Manager", "Admin"],
    "roleChangeRoles": ["CEO", "Manager"],
    "deleteRoles": ["CEO", "Manager"]
  },

  "notes": [
    "User'lar to'liq SAP OSLP jadvalida saqlanadi.",
    "GET so'rovlar HANA SQL orqali, CREATE/UPDATE Service Layer (B1 SL) orqali.",
    "Parol plaintext (SAP'da U_password) — bcrypt yo'q.",
    "Yangi user yaratilganda parol o'rnatilmaydi — user /auth/forgot/otp orqali parol o'rnatadi.",
    "Avatar, isActive, isDeleted SAP'da emas, MongoDB SalesPersonProfile collection'da saqlanadi.",
    "Role o'zgartirish faqat CEO va Manager qo'lida (Admin user yarata oladi, ammo role'ni o'zgartira olmaydi).",
    "O'chirish (soft delete) va tiklash faqat CEO va Manager qo'lida.",
    "isDeleted=true yoki isActive=false bo'lgan user /login orqali kira olmaydi.",
    "OTP oqimlari 3 bosqichli: otp -> verify -> complete. /verify regToken (JWT, TTL 10 min) qaytaradi, /complete shu regToken bilan ishlaydi."
  ],

  "endpoints": {

    "POST /login": {
      "auth": "public",
      "desc": "Mavjud SAP login. isDeleted=true yoki isActive=false bo'lsa rad etadi.",
      "body": { "login": "ali", "password": "1234" },
      "response": { "token": "jwt...", "data": { "SlpCode": 26, "SlpName": "...", "U_role": "OperatorM" } }
    },

    "POST /auth/register/otp": {
      "auth": "public",
      "desc": "1-bosqich. Birinchi marta parol o'rnatish uchun OTP yuborish.",
      "body": { "phone": "998901234567" },
      "response": { "delivered": true, "chatHint": "99890***67", "login": "ali", "expiresAt": "..." }
    },

    "POST /auth/register/verify": {
      "auth": "public",
      "desc": "2-bosqich. OTP kodini tasdiqlab, regToken qaytaradi (TTL 10 min).",
      "body": { "phone": "998901234567", "code": "482917" },
      "response": { "verified": true, "regToken": "eyJ...", "expiresAt": "..." }
    },

    "POST /auth/register": {
      "auth": "public",
      "desc": "3-bosqich. regToken + parol bilan SAP'ga U_password yoziladi.",
      "body": {
        "regToken": "eyJ...",
        "password": "Parol123",
        "passwordConfirm": "Parol123"
      },
      "response": { "message": "Parol o'rnatildi", "slpCode": 90, "login": "ali" }
    },

    "POST /auth/forgot/otp": {
      "auth": "public",
      "desc": "1-bosqich. Parolni tiklash uchun OTP yuborish.",
      "body": { "phone": "998901234567" },
      "response": { "delivered": true, "chatHint": "99890***67", "expiresAt": "..." }
    },

    "POST /auth/forgot/verify": {
      "auth": "public",
      "desc": "2-bosqich. OTP kodini tasdiqlab, regToken qaytaradi.",
      "body": { "phone": "998901234567", "code": "482917" },
      "response": { "verified": true, "regToken": "eyJ...", "expiresAt": "..." }
    },

    "POST /auth/forgot/reset": {
      "auth": "public",
      "desc": "3-bosqich. regToken + yangi parol bilan SAP'ga yoziladi.",
      "body": {
        "regToken": "eyJ...",
        "newPassword": "YangiParol",
        "passwordConfirm": "YangiParol"
      },
      "response": { "message": "Parol yangilandi", "slpCode": 26, "login": "ali" }
    },

    "GET /me": {
      "auth": "self",
      "response": { "data": { "SlpCode": 26, "SlpName": "...", "U_login": "ali", "U_role": "OperatorM", "Mobil": "...", "isActive": true, "isDeleted": false, "avatar": { "keys": {}, "urls": {} } } }
    },

    "POST /me/avatar": {
      "auth": "self",
      "contentType": "multipart/form-data",
      "body": { "avatar": "<file: jpg/png/webp ≤5MB>" }
    },

    "POST /me/credentials/otp": {
      "auth": "self",
      "desc": "1-bosqich. Login+parolni o'zgartirish uchun OTP yuborish.",
      "body": null,
      "response": { "delivered": true, "chatHint": "99890***67", "expiresAt": "..." }
    },

    "POST /me/credentials/verify": {
      "auth": "self",
      "desc": "2-bosqich. OTP'ni tasdiqlab, regToken qaytaradi.",
      "body": { "code": "482917" },
      "response": { "verified": true, "regToken": "eyJ...", "expiresAt": "..." }
    },

    "PATCH /me/credentials": {
      "auth": "self",
      "desc": "3-bosqich. regToken + login + parol birga yangilanadi.",
      "body": {
        "regToken": "eyJ...",
        "newLogin": "yangi.login",
        "newPassword": "Yangi123",
        "passwordConfirm": "Yangi123"
      },
      "response": { "message": "Login va parol yangilandi" }
    },

    "GET /sap-users": {
      "auth": "admin",
      "query": {
        "search": "ali",
        "role": "Operator1",
        "branch": "1",
        "isActive": "true | false",
        "includeDeleted": "true (default false)"
      }
    },

    "GET /sap-users/:slpCode": { "auth": "admin" },

    "POST /sap-users": {
      "auth": "admin",
      "desc": "SAP'da SalesPerson yaratadi. Parolsiz. Profil avtomatik isActive=true bo'ladi.",
      "body": {
        "fullName": "Ali Valiyev",
        "login": "ali.v",
        "role": "Operator1",
        "branch": "1",
        "mobile": "998901234567",
        "telephone": "...",
        "onlinePbx": "115",
        "workDay": "1,2,3,4,5",
        "summa": 3000000
      },
      "multipartExtra": { "avatar": "<file ixtiyoriy>" }
    },

    "PATCH /sap-users/:slpCode": {
      "auth": "admin",
      "desc": "Login/password BU YERDA o'zgarmaydi. Role faqat CEO/Manager o'zgartira oladi.",
      "body": {
        "fullName": "...",
        "role": "Operator2 — faqat CEO/Manager o'zgartira oladi",
        "branch": "2",
        "mobile": "998...",
        "telephone": "...",
        "onlinePbx": "120",
        "workDay": "1,2,3",
        "summa": 4000000
      }
    },

    "POST /sap-users/:slpCode/avatar": {
      "auth": "admin",
      "contentType": "multipart/form-data",
      "body": { "avatar": "<file>" }
    },

    "POST /sap-users/:slpCode/activate": {
      "auth": "admin",
      "desc": "isActive=true. O'chirilgan akkauntda ishlamaydi — avval restore qiling.",
      "body": null
    },

    "POST /sap-users/:slpCode/deactivate": {
      "auth": "admin",
      "desc": "isActive=false. User login bo'la olmaydi.",
      "body": null
    },

    "DELETE /sap-users/:slpCode": {
      "auth": "ceo_manager",
      "desc": "Soft delete (isDeleted=true, isActive=false). SAP'dan o'chirilmaydi.",
      "body": null
    },

    "POST /sap-users/:slpCode/restore": {
      "auth": "ceo_manager",
      "desc": "isDeleted=false, isActive=true.",
      "body": null
    }
  },

  "errorFormat": { "message": "Xatolik matni", "errors": [] },

  "flows": {
    "1_adminCreatesUser": [
      "POST /login (admin) → token",
      "POST /sap-users {fullName, login, role, mobile, branch, ...}"
    ],
    "2_userRegistersFirstTime": [
      "POST /auth/register/otp {phone}",
      "POST /auth/register/verify {phone, code} → regToken",
      "POST /auth/register {regToken, password, passwordConfirm}"
    ],
    "3_userLogsIn": ["POST /login {login, password}"],
    "4_userForgotPassword": [
      "POST /auth/forgot/otp {phone}",
      "POST /auth/forgot/verify {phone, code} → regToken",
      "POST /auth/forgot/reset {regToken, newPassword, passwordConfirm}"
    ],
    "5_userChangesCredentials": [
      "POST /me/credentials/otp",
      "POST /me/credentials/verify {code} → regToken",
      "PATCH /me/credentials {regToken, newLogin, newPassword, passwordConfirm}"
    ],
    "6_adminUpdatesUser": ["PATCH /sap-users/:slpCode (role faqat CEO/Manager)"],
    "7_deactivateAndReactivate": [
      "POST /sap-users/:slpCode/deactivate (admin)",
      "POST /sap-users/:slpCode/activate (admin)"
    ],
    "8_softDeleteAndRestore": [
      "DELETE /sap-users/:slpCode (CEO/Manager)",
      "POST /sap-users/:slpCode/restore (CEO/Manager)"
    ]
  }
}
